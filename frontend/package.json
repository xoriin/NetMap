{
  "name": "netmap-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js --host 0.0.0.0",
    "build": "tsc && vite build",
    "analyze": "vite build && xdg-open dist/stats.html 2>/dev/null || open dist/stats.html 2>/dev/null || true",
    "preview": "vite preview --host 0.0.0.0",
    "import-icon-pack": "node ./scripts/import-icon-pack.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.5",
    "@tabler/icons-react": "^3.43.0",
    "cytoscape": "^3.33.1",
    "dompurify": "^3.2.6",
    "lucide-react": "^0.468.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "latest",
    "rollup-plugin-visualizer": "^6.0.11",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
